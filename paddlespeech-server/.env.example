# paddlespeech-server 本地环境变量（复制为 .env 后按需填写）
# .env 已在 .gitignore 中，不会被提交。

# ---------- Python / venv ----------
# 留空则默认使用本目录 ./.venv
# PADDLE_VENV=./.venv

# 创建 venv 时使用的解释器（仅 ./start.sh 安装阶段；SKIP_SETUP 时不读）
# PYTHON_BIN=python3.11

# ---------- 服务配置 ----------
# PaddleSpeech yaml；默认 ./conf/tts_online_application.yaml
# PADDLESPEECH_CONFIG=./conf/tts_online_application.yaml
# 监听地址（默认所有网卡；与 conf/tts_online_application.yaml 中 host/port 一致时可省略）
PADDLESPEECH_HOST=0.0.0.0
# PADDLESPEECH_PORT=8092

# ---------- pip ----------
# 国内镜像可加速 paddle / paddlespeech 大 wheel 下载
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/

# ---------- start.sh 快捷开关 ----------
# SKIP_SETUP=1
# SETUP_ONLY=1
# FAST_START=1
