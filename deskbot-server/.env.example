# deskbot-server 本地环境变量（复制为 .env 后填写）
# 勿提交含真实密钥的 .env

# ---------- 必填 ----------
# DashScope OpenAI 兼容 API Key（也可用 DASHSCOPE_API_KEY / QWEN_API_KEY）
LLM_API_KEY=

# 本地 ASR 模型目录（相对 deskbot-server/）
ASR_MODEL_DIR=./models/SenseVoiceSmall

# ---------- 常用可选 ----------
# 主配置文件（默认 config.yaml）
# DESKBOT_SERVER_CONFIG=config.yaml

# WebSocket 服务
# DESKBOT_SERVER_HOST=0.0.0.0
# DESKBOT_SERVER_PORT=9000
# DESKBOT_WS_PATH=/asr_chat
# DESKBOT_WS_PING_INTERVAL=120
# DESKBOT_WS_PING_TIMEOUT=300
# WS_SEND_TIMEOUT_SEC=10

# TTS 连接（默认读 config.yaml tts.*）
# TTS_WS_URL=ws://127.0.0.1:8092/paddlespeech/tts/streaming
# TTS_SPK_ID=0
# TTS_SAMPLE_RATE=24000

# pb 脸动画（默认读 config.yaml tts.pb_face_bundle_json）
# DESKBOT_PB_FACE_BUNDLE_JSON=data/pb_face_bundle_demo.json
# DESKBOT_PB_FACE_BUNDLE_FILE=data/pb_face_bundle_demo_overlay.yaml

# 下行协议开关（默认 pb-only=true，见 config.yaml server.*）
# DESKBOT_ASR_CHAT_DEVICE_PB_ONLY=1
# DESKBOT_ASR_CHAT_MINIMAL_DOWNLINK=0
# DESKBOT_SEND_FACE_INFO=0
# DESKBOT_PB_RANDOM_SERVO=0
# DESKBOT_PB_IDLE_SNORE_SEC=5
# DESKBOT_PB_IDLE_SNORE_SCENE=sleep_snore

# Flask 调试台（默认监听所有网卡，局域网可访问）
DESKBOT_WEB_HOST=0.0.0.0
# DESKBOT_WEB_PORT=5050
# DESKBOT_WEB_PUBLIC_HOST=

# 摄像头（默认读 config.yaml camera_face.*）
# CAMERA_FACE_LANDMARKER_PATH=
# CAMERA_UNDISTORT=0
# CAMERA_CALIB_JSON=
# CAMERA_MIN_FACE_DETECTION_CONFIDENCE=
# CAMERA_MIN_FACE_PRESENCE_CONFIDENCE=

# 日志
# DESKBOT_SERVER_LOG_FILE=app.log
# DESKBOT_SERVER_LOG_LEVEL=INFO

# ---------- 启动脚本 ----------
# 跳过 pip 重装（venv 须已完整）
FAST_START=0
